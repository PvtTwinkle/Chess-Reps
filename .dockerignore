# Dependencies — reinstalled inside the container during build
node_modules

# SvelteKit generated files — rebuilt inside the container
.svelte-kit

# Git history — not needed in the image
.git

# SQLite database — mounted as a volume at runtime, never baked into the image
data

# Local environment file — secrets must never be baked into an image
.env
.env.*

# Editor and OS noise
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
