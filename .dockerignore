# Dependencies — reinstalled inside the container during build
node_modules

# SvelteKit generated files — rebuilt inside the container
.svelte-kit
build

# Git history — not needed in the image
.git
.github

# Database data directory — data lives in a Docker volume, not baked into the image
data

# Local environment file — secrets must never be baked into an image
.env
.env.*

# Editor and OS noise
.DS_Store
Thumbs.db

# Large data files used for offline tooling, not needed in the app
*.pgn
fens-all.tsv
lichess_db_puzzle.csv

# Claude Code config — development tool, not needed in the image
.claude
CLAUDE.md

# Documentation — not needed at runtime
README.md
CHANGELOG.md
CONTRIBUTING.md
SECURITY.md
THIRD-PARTY-NOTICES.md
chess-opening-trainer-brief-v3.md

# Docker files — not needed inside the image
Dockerfile
Dockerfile.*
docker-compose.yml

# Dev tooling configs — not needed at runtime
scripts
.prettierrc
.prettierignore
.pre-commit-config.yaml
eslint.config.js
drizzle.config.ts

# Seed dumps are downloaded inside the Dockerfile (seeds stage) from
# GitHub Releases — they do not need to be in the build context.
*.sql.gz

# Logs
*.log
npm-debug.log*
