		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^22",
		"drizzle-kit": "^0.31.9",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-no-unsanitized": "^4.1.5",
		"eslint-plugin-security": "^4.0.0",
